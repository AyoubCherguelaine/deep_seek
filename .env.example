# Server
APP_NAME=deepseek-ocr-api
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# GPU
CUDA_VISIBLE_DEVICES=0

# Model
MODEL_NAME=deepseek-ai/DeepSeek-OCR-2

# Flash attention is faster, but can fail depending on CUDA/PyTorch build.
# The app automatically retries without it if model loading fails.
USE_FLASH_ATTENTION=true

# Safer 16GB VRAM default for single-GPU deployment:
# base_size=640, image_size=640, crop_mode=false
BASE_SIZE=640
IMAGE_SIZE=640
CROP_MODE=false
TEST_COMPRESS=false

# If you get CUDA OOM, use:
# BASE_SIZE=512
# IMAGE_SIZE=512
# CROP_MODE=false
# TEST_COMPRESS=false

# OCR prompt
DEFAULT_PROMPT=<image>\n<|grounding|>Convert the document to markdown. 

# Upload limits
MAX_UPLOAD_MB=40
MAX_PDF_PAGES=10

# Runtime
REQUEST_TIMEOUT_SECONDS=180
TEMP_DIR=/tmp/deepseek_ocr

# Auth
# A long-lived (1 year) bearer token mechanism.
# Set AUTH_API_KEY to a strong secret. If empty, /auth/token is disabled
# and /ocr is open (only do this for local development).
AUTH_API_KEY=change-me-to-a-strong-secret
AUTH_TOKEN_TTL_DAYS=365
