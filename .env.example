# Server
APP_NAME=deepseek-ocr-api
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# GPU
CUDA_VISIBLE_DEVICES=0

# Model
MODEL_NAME=deepseek-ai/DeepSeek-OCR-2

# FlashAttention is optional. RTX 50 works with PyTorch SDPA; only enable this
# when a compatible flash-attn package is already installed or runtime install
# is explicitly allowed.
USE_FLASH_ATTENTION=false
ALLOW_FLASH_ATTENTION_INSTALL=false

# OCR defaults. These use DeepSeek-OCR-2's native 768/1024 query sizes.
BASE_SIZE=1024
IMAGE_SIZE=768
CROP_MODE=true
TEST_COMPRESS=false
SAVE_OCR_RESULTS=false

# Faster, lower-quality mode:
# BASE_SIZE=640
# IMAGE_SIZE=640

# OCR prompt
DEFAULT_PROMPT=<image>\nFree OCR. 

# Upload limits
MAX_UPLOAD_MB=40

# Runtime
REQUEST_TIMEOUT_SECONDS=180
TEMP_DIR=/tmp/deepseek_ocr

# Auth
# A long-lived (1 year) bearer token mechanism.
# Set AUTH_API_KEY to a strong secret. If empty, /auth/token is disabled
# and /ocr is open (only do this for local development).
AUTH_API_KEY=change-me-to-a-strong-secret
AUTH_TOKEN_TTL_DAYS=365
