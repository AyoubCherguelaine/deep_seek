# Server
APP_NAME=unlimited-ocr-api
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# GPU
CUDA_VISIBLE_DEVICES=0

# Model
MODEL_NAME=baidu/Unlimited-OCR

# OCR defaults
DEFAULT_PROMPT=document parsing. If Quranic verses are present, do not transcribe the verse text. Instead identify only the surah name or number and the ayah number when visible or confidently inferable. If uncertain, write 'Quranic verse detected - surah unknown, ayah unknown'.

# /ocr/base: accurate single-image mode
BASE_SIZE_BASE=1024
IMAGE_SIZE_BASE=1024

# /ocr/long: faster crop mode for PDFs and long documents
BASE_SIZE_LONG=1024
IMAGE_SIZE_LONG=640

# Generation controls
MAX_LENGTH=8192
NO_REPEAT_NGRAM_SIZE=35
NGRAM_WINDOW=128

# PDF conversion
PDF_DPI=200
MAX_PDF_PAGES=200

# Upload/runtime
MAX_UPLOAD_MB=80
REQUEST_TIMEOUT_SECONDS=300
TEMP_DIR=/tmp/unlimited_ocr

# Auth
# Set AUTH_API_KEY to a strong secret. If empty, /auth/token is disabled
# and OCR endpoints are open, which should only be used for local development.
AUTH_API_KEY=change-me-to-a-strong-secret
AUTH_TOKEN_TTL_DAYS=365
