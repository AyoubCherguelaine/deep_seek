# Server
APP_NAME=deepseek-ocr-api
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# GPU
CUDA_VISIBLE_DEVICES=0

# Model
MODEL_NAME=deepseek-ai/DeepSeek-OCR-2

# FlashAttention is optional. RTX 50 works with PyTorch SDPA; only enable this
# when a compatible flash-attn package is already installed or runtime install
# is explicitly allowed.
USE_FLASH_ATTENTION=false
ALLOW_FLASH_ATTENTION_INSTALL=false

# OCR defaults. These use DeepSeek-OCR-2's native 768/1024 query sizes.
BASE_SIZE=1024
IMAGE_SIZE=768
CROP_MODE=true
TEST_COMPRESS=false
SAVE_OCR_RESULTS=false

# Faster, lower-quality mode:
# BASE_SIZE=640
# IMAGE_SIZE=640

# OCR prompt
# Extract plain text, preserve math/physics formulas as LaTeX, and return
# grounding boxes for images/figures/diagrams when present.
DEFAULT_PROMPT=<image>\n<|grounding|>Extract all visible document content into clean Markdown. Preserve reading order. Transcribe normal text exactly. If the page contains mathematics, physics, chemistry, or technical notation, write every formula in valid LaTeX using inline `$...$` or display `$$...$$` form as appropriate. Preserve equation numbers, variables, units, superscripts, subscripts, fractions, roots, vectors, matrices, and symbols. For tables, return Markdown tables. For any photo, figure, diagram, chart, graph, or boxed visual region, include an image/figure item with a short description and its bounding box points as `[x1,y1,x2,y2]` in image pixel coordinates. If a boxed question, boxed answer, highlighted region, or callout exists, return its box points too. Do not invent missing text. Mark unreadable parts as `[illegible]`.

# Upload limits
MAX_UPLOAD_MB=40

# Runtime
REQUEST_TIMEOUT_SECONDS=180
TEMP_DIR=/tmp/deepseek_ocr

# Auth
# A long-lived (1 year) bearer token mechanism.
# Set AUTH_API_KEY to a strong secret. If empty, /auth/token is disabled
# and /ocr is open (only do this for local development).
AUTH_API_KEY=change-me-to-a-strong-secret
AUTH_TOKEN_TTL_DAYS=365
